# API 模式配置
# mock: 使用模拟数据（默认）
# real: 使用真实 API
VITE_API_MODE=mock

# 远程 API 地址（当 VITE_API_MODE=real 时生效）
VITE_API_URL=http://localhost:5000

# 认证服务器地址
VITE_AUTH_URL=https://auth.abcsxl.com

# 示例：连接到生产环境 API
# VITE_API_URL=https://api.openfindbearings.com

# 示例：连接到测试环境 API
# VITE_API_URL=https://api-test.openfindbearings.com
